<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    package="com.ramzi.obdpro">

    <!-- ════════════════════════════════════════════════════════════════════
         BLUETOOTH PERMISSIONS
         - Legacy permissions (API < 31) need BLUETOOTH + BLUETOOTH_ADMIN
         - Android 12+ (API 31+) needs BLUETOOTH_SCAN + BLUETOOTH_CONNECT
         - Fine location required for BT scanning on Android 10+
         ════════════════════════════════════════════════════════════════════ -->

    <!-- Legacy Bluetooth (API < 31) -->
    <uses-permission android:name="android.permission.BLUETOOTH"
        android:maxSdkVersion="30" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADMIN"
        android:maxSdkVersion="30" />

    <!-- Android 12+ Bluetooth -->
    <uses-permission android:name="android.permission.BLUETOOTH_SCAN"
        android:usesPermissionFlags="neverForLocation"
        tools:targetApi="s" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />

    <!-- Location — required for BT discovery on Android 10+ -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- Foreground service for persistent BT connection -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CONNECTED_DEVICE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Declare that this app uses Bluetooth Classic (not BLE-only) -->
    <uses-feature android:name="android.hardware.bluetooth" android:required="true" />

    <application
        android:name=".ObdApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="OBD Pro"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.OBDPro"
        tools:targetApi="34">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.OBDPro"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <service
            android:name=".service.ObdService"
            android:foregroundServiceType="connectedDevice"
            android:exported="false" />
    </application>
</manifest>
